{# Python compose template: multiple constructs wired together #}
{% for imp in imports %}
from {{ imp.module }} import {{ imp.names | join(", ") }}
{% endfor %}
{% for block in blocks %}

{% if block.comment %}
# {{ block.comment }}
{% endif %}
{{ block.id }} = {{ block.construct_name }}(self, "{{ block.construct_id }}",
{% for prop in block.props %}
{% if prop.is_placeholder %}
    # TODO: Required — {{ prop.comment }}
    {{ prop.name }}="{{ prop.placeholder }}",
{% elif prop.has_warning %}
    {{ prop.name }}={{ prop.value }},  # WARNING: expected {{ prop.expected_type }}, got {{ prop.actual_type }}
{% elif prop.is_wired %}
    # Wired from {{ prop.source_construct }}
    {{ prop.name }}={{ prop.value }},
{% elif prop.is_security_default %}
    # 🔒 {{ prop.comment }}
    {{ prop.name }}={{ prop.value }},
{% elif prop.comment %}
    # {{ prop.comment }}
    {{ prop.name }}={{ prop.value }},
{% else %}
    {{ prop.name }}={{ prop.value }},
{% endif %}
{% endfor %}
)
{% endfor %}
