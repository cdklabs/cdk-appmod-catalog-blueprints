{# Python scaffold template: single construct instantiation with snake_case props #}
{% if dependency_hint %}
# Install: {{ dependency_hint }}
{% endif %}
{% for imp in imports %}
from {{ imp.module }} import {{ imp.names | join(", ") }}
{% endfor %}

{{ id }} = {{ construct_name }}(self, "{{ construct_id }}",
{% for prop in props %}
{% if prop.is_placeholder %}
    # TODO: Required — {{ prop.comment }}
    {{ prop.name }}="{{ prop.placeholder }}",
{% elif prop.has_warning %}
    {{ prop.name }}={{ prop.value }},  # WARNING: expected {{ prop.expected_type }}, got {{ prop.actual_type }}
{% elif prop.is_security_default %}
    # 🔒 {{ prop.comment }}
    {{ prop.name }}={{ prop.value }},
{% elif prop.comment %}
    # {{ prop.comment }}
    {{ prop.name }}={{ prop.value }},
{% else %}
    {{ prop.name }}={{ prop.value }},
{% endif %}
{% endfor %}
)
{% if has_observability %}

# --- Observability (uncomment to enable) ---
# observability = ServerlessObservability(self, "Observability",
#     lambda_functions=[{{ id }}],
# )
{% endif %}
