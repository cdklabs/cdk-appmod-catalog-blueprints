{# TypeScript scaffold template: single construct instantiation with smart defaults #}
{% if dependency_hint %}
// Install: {{ dependency_hint }}
{% endif %}
{% for imp in imports %}
import { {{ imp.names | join(', ') }} } from '{{ imp.module }}';
{% endfor %}

const {{ id }} = new {{ construct_name }}(this, '{{ construct_id }}', {
{% for prop in props %}
{% if prop.is_placeholder %}
  // TODO: Required — {{ prop.comment }}
  {{ prop.name }}: '{{ prop.placeholder }}',
{% elif prop.has_warning %}
  {{ prop.name }}: {{ prop.value }}, // WARNING: expected {{ prop.expected_type }}, got {{ prop.actual_type }}
{% elif prop.is_security_default %}
  // 🔒 {{ prop.comment }}
  {{ prop.name }}: {{ prop.value }},
{% elif prop.comment %}
  // {{ prop.comment }}
  {{ prop.name }}: {{ prop.value }},
{% else %}
  {{ prop.name }}: {{ prop.value }},
{% endif %}
{% endfor %}
});
{% if has_observability %}

// --- Observability (uncomment to enable) ---
// To enable observability with Lambda Powertools, X-Ray tracing,
// and CloudWatch metrics, set enableObservability to true above
// or add the following:
// const observability = new ServerlessObservability(this, 'Observability', {
//   lambdaFunctions: [{{ id }}],
// });
{% endif %}
