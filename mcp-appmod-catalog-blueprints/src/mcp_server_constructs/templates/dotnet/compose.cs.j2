{# .NET compose template: multiple constructs wired together #}
{% if dependency_hint %}
// Install: {{ dependency_hint }}
{% endif %}
{% for imp in imports %}
using {{ imp.module }};
{% endfor %}
{% for block in blocks %}

{% if block.comment %}
// {{ block.comment }}
{% endif %}
var {{ block.id }} = new {{ block.construct_name }}(this, "{{ block.construct_id }}", new {{ block.construct_name }}Props
{
{% for prop in block.props %}
{% if prop.is_placeholder %}
    // TODO: Required — {{ prop.comment }}
    {{ prop.name }} = "{{ prop.placeholder }}",
{% elif prop.has_warning %}
    {{ prop.name }} = {{ prop.value }}, // WARNING: expected {{ prop.expected_type }}, got {{ prop.actual_type }}
{% elif prop.is_wired %}
    // Wired from {{ prop.source_construct }}
    {{ prop.name }} = {{ prop.value }},
{% elif prop.is_security_default %}
    // 🔒 {{ prop.comment }}
    {{ prop.name }} = {{ prop.value }},
{% elif prop.comment %}
    // {{ prop.comment }}
    {{ prop.name }} = {{ prop.value }},
{% else %}
    {{ prop.name }} = {{ prop.value }},
{% endif %}
{% endfor %}
});
{% endfor %}
