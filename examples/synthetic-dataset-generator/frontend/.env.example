# DataSynth Frontend Configuration
# Copy this file to .env and fill in values from CDK stack outputs

# API endpoint (ChatApiEndpoint from CDK output)
VITE_API_ENDPOINT=

# Cognito User Pool ID (UserPoolId from CDK output)
VITE_USER_POOL_ID=

# Cognito User Pool Client ID (UserPoolClientId from CDK output)
VITE_USER_POOL_CLIENT_ID=

# AWS Region (optional, defaults to us-east-1)
VITE_AWS_REGION=us-east-1
