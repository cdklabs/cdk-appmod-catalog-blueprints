# These values are set during the build process

REACT_APP_CHAT_API_ENDPOINT=https://bedrock-agentcore.us-east-1.amazonaws.com/runtimes/<URL-ENCODED-RUNTIME-ARN>/invocations?qualifier=retail_banking_endpoint
